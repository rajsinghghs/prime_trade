# ─── Application ───────────────────────────────────────────────────────────────
APP_NAME=PrimeTrade API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# ─── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql://postgres:password@localhost:5432/primetrade_db

# ─── JWT Security ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-64-char-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Redis (Optional Caching) ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:5500","http://localhost:5500"]
