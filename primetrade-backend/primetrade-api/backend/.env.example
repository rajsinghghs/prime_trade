# ============================================
# PRIMETRADE API - Environment Configuration
# ============================================

# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=primetrade_db
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=30d

# Redis (Optional Caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500

# Bcrypt
BCRYPT_ROUNDS=12

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log
